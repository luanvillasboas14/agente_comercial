# Copie para ".env" na raiz do projeto e preencha os valores.
# Nunca commite o arquivo ".env".

# ── Servidor Node (npm run server / produção) ──
PORT=8000

# OpenAI (obrigatório para job de feedback e tool inscrição no servidor)
OPENAI_API_KEY=

# Opcional: pré-preenche a chave no Playground (Vite expõe ao browser — use só em dev)
# VITE_OPENAI_API_KEY=

# ── Supabase: base principal (IA / vetores / inscrição / distribuição) ──
SUPABASE_URL=
SUPABASE_KEY=
# distrib_comercial (consultores): por padrão usa SUPABASE_*_FEEDBACK abaixo.
# Override opcional:
# SUPABASE_URL_DIST_COMERCIAL=
# SUPABASE_KEY_DIST_COMERCIAL=
# Alternativa se o front precisar (dev): pode repetir com prefixo VITE_
# VITE_SUPABASE_URL=
# VITE_SUPABASE_KEY=

# ── Supabase: feedback comercial (tabelas do job) ──
SUPABASE_URL_FEEDBACK=
SUPABASE_KEY_FEEDBACK=
# VITE_SUPABASE_URL_FEEDBACK=
# VITE_SUPABASE_KEY_FEEDBACK=

# ── Google Maps (tool localização / polos) ──
GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_API_KEY=

# Opcional: outro projeto só para tabela polo_loc
# SUPABASE_POLO_URL=
# SUPABASE_POLO_KEY=
# SUPABASE_POLO_TABLE=polo_loc

# ── Kommo (tool inscrição) ──
# URL da conta (sem barra no final). Teste: GET {KOMMO_BASE_URL}/api/v4/account
KOMMO_BASE_URL=https://admamoeduitcombr.kommo.com
KOMMO_ACCESS_TOKEN=

# Opcionais (o código tem defaults do fluxo antigo se omitir)
# KOMMO_SALESBOT_BOT_ID=46605
# KOMMO_PIPELINE_ID=5481944
# KOMMO_STATUS_ID=48539246
# Opcional — etapa “Aguardando inscrição” (default no código: 99045180, mesmo funil)
# KOMMO_STATUS_AGUARDANDO_INSCRICAO=99045180
# Distribuição humana (defaults no código = fluxo n8n tool distribuir.txt)
# KOMMO_DISTRIB_PIPELINE_ID=11685120
# KOMMO_DISTRIB_STATUS_IDS=89820300,89820304
# KOMMO_DISTRIB_ASSIGN_STATUS_ID=89820300
# KOMMO_DISTRIB_FINAL_PIPELINE_ID=5481944
# KOMMO_DISTRIB_FINAL_STATUS_ID=48539246
# Campo select “Recebida” — se o PATCH falhar, defina o enum_id numérico do Kommo:
# KOMMO_DIST_ORIGEM_ENUM_ID=
# Só testes locais: simula nome/nível no POST /api/inscricao/run (body _test_*)
# INSCRICAO_TEST_OVERRIDES=true

# ── Job de feedback (cron no server e no Vite dev) ──
# FEEDBACK_JOB_ENABLED=true
# FEEDBACK_JOB_WINDOW_MINUTES=90
# FEEDBACK_JOB_BUFFER_MINUTES=30
# FEEDBACK_JOB_MAX_WINDOW_MINUTES=0
