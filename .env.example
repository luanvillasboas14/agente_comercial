# Copie para ".env" na raiz do projeto e preencha os valores.
# Nunca commite o arquivo ".env".

# ── Servidor Node (npm run server / produção) ──
PORT=8000

# OpenAI (obrigatório para job de feedback e tool inscrição no servidor)
OPENAI_API_KEY=

# Opcional: pré-preenche a chave no Playground (Vite expõe ao browser — use só em dev)
# VITE_OPENAI_API_KEY=

# ── Supabase: base principal (IA / vetores / inscrição / distribuição) ──
SUPABASE_URL=
SUPABASE_KEY=
# Tabela de memória do agente (n8n Postgres Chat Memory). Default: n8n_chat_histories
# N8N_MEMORY_TABLE=n8n_chat_histories
# distrib_comercial (consultores): por padrão usa SUPABASE_*_FEEDBACK abaixo.
# Override opcional:
# SUPABASE_URL_DIST_COMERCIAL=
# SUPABASE_KEY_DIST_COMERCIAL=
# Alternativa se o front precisar (dev): pode repetir com prefixo VITE_
# VITE_SUPABASE_URL=
# VITE_SUPABASE_KEY=

# ── Supabase: feedback comercial (tabelas do job) ──
SUPABASE_URL_FEEDBACK=
SUPABASE_KEY_FEEDBACK=
# VITE_SUPABASE_URL_FEEDBACK=
# VITE_SUPABASE_KEY_FEEDBACK=

# ── Google Maps (tool localização / polos) ──
GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_API_KEY=

# Opcional: outro projeto só para tabela polo_loc
# SUPABASE_POLO_URL=
# SUPABASE_POLO_KEY=
# SUPABASE_POLO_TABLE=polo_loc

# ── Kommo (tool inscrição) ──
# URL da conta (sem barra no final). Teste: GET {KOMMO_BASE_URL}/api/v4/account
KOMMO_BASE_URL=https://admamoeduitcombr.kommo.com
KOMMO_ACCESS_TOKEN=

# Opcionais (o código tem defaults do fluxo antigo se omitir)
# KOMMO_SALESBOT_BOT_ID=46605
# KOMMO_PIPELINE_ID=5481944
# KOMMO_STATUS_ID=48539246
# Opcional — etapa “Aguardando inscrição” (default no código: 99045180, mesmo funil)
# KOMMO_STATUS_AGUARDANDO_INSCRICAO=99045180
# Distribuição humana (defaults no código = fluxo n8n tool distribuir.txt)
# KOMMO_DISTRIB_PIPELINE_ID=11685120
# KOMMO_DISTRIB_STATUS_IDS=89820300,89820304
# KOMMO_DISTRIB_ASSIGN_STATUS_ID=89820300
# KOMMO_DISTRIB_FINAL_PIPELINE_ID=5481944
# KOMMO_DISTRIB_FINAL_STATUS_ID=48539246
# Campo select “Recebida” — se o PATCH falhar, defina o enum_id numérico do Kommo:
# KOMMO_DIST_ORIGEM_ENUM_ID=
# Só testes locais: simula nome/nível no POST /api/inscricao/run (body _test_*)
# INSCRICAO_TEST_OVERRIDES=true

# ── Job de feedback (cron no server e no Vite dev) ──
# FEEDBACK_JOB_ENABLED=true
# FEEDBACK_JOB_WINDOW_MINUTES=90
# FEEDBACK_JOB_BUFFER_MINUTES=30
# FEEDBACK_JOB_MAX_WINDOW_MINUTES=0
# Intervalo esperado entre runs (min); acima disso amplia o lookback até MAX_LOOKBACK_EXTENSION
# FEEDBACK_JOB_EXPECTED_INTERVAL_MINUTES=60
# FEEDBACK_JOB_MAX_LOOKBACK_EXTENSION_MINUTES=120
# true = um “cron” por hora UTC no cluster (recomendado com várias réplicas)
# FEEDBACK_JOB_USE_HOUR_SLOT_LOCK=true
# true = catch-up ao subir o processo (pode duplicar com cron se não usar slot lock)
# FEEDBACK_JOB_STARTUP_CATCHUP=false

# ── Buffer de mensagens do WhatsApp (debounce entre mensagens do lead) ──
# Seleção automática: 1) Redis se configurado, 2) Supabase (principal) como fallback
# persistente, 3) memória (não persiste em restart).
#
# Supabase (recomendado, default): precisa das envs SUPABASE_URL/SUPABASE_KEY acima
# e da tabela criada uma única vez (SQL):
#   CREATE TABLE message_buffer (
#     id bigserial PRIMARY KEY,
#     session_id text NOT NULL,
#     content text NOT NULL,
#     created_at timestamptz NOT NULL DEFAULT now()
#   );
#   CREATE INDEX message_buffer_session_id_idx ON message_buffer (session_id, id);
# Nome da tabela (default: message_buffer)
# MESSAGE_BUFFER_TABLE=message_buffer
#
# Redis (opcional — só se quiser priorizar Redis em vez de Supabase):
# REDIS_URL=redis://:senha@host:6379/0
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false
# REDIS_KEY_PREFIX=wa:msg:
#
# Forçar backend: redis | supabase | memory (sem valor = auto conforme acima)
# MESSAGE_BUFFER_BACKEND=

# ── Webhook Evolution API ──
# Tempo (segundos) para juntar mensagens do lead antes de enviar ao agente
# MESSAGE_DEBOUNCE_SECONDS=15
# Token opcional — se setado, a Evolution precisa enviar X-Webhook-Token ou Authorization: Bearer <token>
# EVOLUTION_WEBHOOK_TOKEN=

# ── Agente (webhook + /api/agent/run) ──
# Modelo usado pelo agente no servidor (default: gpt-4o-mini)
# OPENAI_AGENT_MODEL=gpt-4o-mini
# Modelo de transcrição de áudio (default: whisper-1)
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# Modelo de análise de imagem (default: gpt-4o-mini)
# OPENAI_VISION_MODEL=gpt-4o-mini
# Quantas mensagens do n8n_chat_histories injetar como turnos anteriores (default: 8)
# AGENT_HISTORY_CONTEXT=8

# ── Envio de resposta pelo WhatsApp Cloud API (Meta/WACA) ──
# Usado no final do fluxo do webhook Evolution: depois que o agente responde,
# a gente divide a resposta em partes (smartSplit) e envia por aqui, criando
# uma nota no Kommo para cada parte (como o fluxo "envio mensagem.txt" do n8n).
# Phone Number ID do WhatsApp Business (no Meta Business)
# WHATSAPP_PHONE_NUMBER_ID=440327379171310
# Access token do Meta (WACA)
# WHATSAPP_ACCESS_TOKEN=
# Versão da Graph API (default v19.0)
# WHATSAPP_API_VERSION=v19.0
# Tamanho máximo de cada pedaço (default 1000, mesmo valor do n8n)
# WHATSAPP_MAX_CHARS=1000
# Espera entre pedaços (default 1000ms, mesmo valor do n8n)
# WHATSAPP_CHUNK_DELAY_MS=1000
